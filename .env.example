# mark-still-growing 环境变量配置模板
# 复制此文件为 .env 并填入实际值（仅在使用外部API时需要）

# ============ 可选配置 ============

# OpenAlex API（学术论文搜索，无需API Key，免费）
# OPENALEX_API_URL=https://api.openalex.org

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/still-growing.log

# 数据目录（默认 ./data）
DATA_DIR=./data

# Python脚本路径（用于 scheduler.py 等）
SCRIPTS_DIR=./scripts
